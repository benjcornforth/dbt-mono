# Databricks connection - compatibility-only env-var example
#
# PREFERRED: Use the modern Databricks CLI and ~/.databrickscfg:
#   databricks auth login --host <workspace-url>
#   forge auth --cli --profile dev
#   add http_path to the matching ~/.databrickscfg profile
#   forge auth --dbt --profile dev
#
# The env vars below are legacy compatibility for local dbt only.
# They are not the primary workflow for this project.
DBT_DATABRICKS_HOST=your-workspace.cloud.databricks.com
DBT_DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
DBT_DATABRICKS_TOKEN=your_personal_access_token
DBT_DATABRICKS_CATALOG=workspace
REQUESTS_CA_BUNDLE=  # macOS: $(python3 -c "import certifi; print(certifi.where())")
